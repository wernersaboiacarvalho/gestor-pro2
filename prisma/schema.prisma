generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  businessType String         // 'workshop', 'salon', 'gym'
  plan         String         @default("free")
  status       String         @default("active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  users          User[]
  customers      Customer[]
  vehicles       Vehicle[]
  serviceOrders  ServiceOrder[]
  mechanics      Mechanic[]
  inventoryItems InventoryItem[]
  suppliers      Supplier[]
  partners         Partner[]
  financialRecords FinancialRecord[]

  @@index([slug])
  @@index([status, createdAt])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  image         String?
  role          String   // 'super_admin', 'admin', 'user'
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedOrders ServiceOrder[] @relation("AssignedMechanic")

  @@index([email])
  @@index([tenantId, role])
}

model Customer {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  cpf       String?
  cnpj      String?
  phone     String
  email     String?
  address   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehicles Vehicle[]

  @@index([tenantId, createdAt])
  @@index([tenantId, cpf])
  @@index([tenantId, phone])
  @@index([tenantId, name])
}

model Vehicle {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  plate      String
  brand      String
  model      String
  year       Int
  color      String?
  imageUrl   String?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  serviceOrders ServiceOrder[]

  @@unique([tenantId, plate])
  @@index([tenantId, customerId])
  @@index([tenantId, brand, model])
}

model ServiceOrder {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mechanicId  String?
  mechanic    User?          @relation("AssignedMechanic", fields: [mechanicId], references: [id])

  orderNumber String
  type        String         @default("budget")   // "budget" | "service_order"
  status      String         @default("draft")     // budget: draft, sent, approved, rejected | service_order: pending, in_progress, completed, delivered, cancelled
  description String
  totalValue  Decimal        @default(0)
  discount    Decimal        @default(0)
  notes       String?
  approvedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items ServiceOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, type, status, createdAt])
  @@index([tenantId, vehicleId])
  @@index([tenantId, mechanicId])
}

model ServiceOrderItem {
  id              String       @id @default(cuid())
  serviceOrderId  String
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  tenantId        String

  type            String       // 'service', 'part'
  description     String
  quantity        Int          @default(1)
  unitValue       Decimal      @default(0)
  totalValue      Decimal      @default(0)
  partnerId       String?
  partner         Partner?     @relation(fields: [partnerId], references: [id])
  partnerCost     Decimal?     // custo real do terceirizado
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([serviceOrderId])
  @@index([tenantId])
  @@index([partnerId])
}

model Mechanic {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  email     String?
  phone     String?
  cpf       String?
  specialty String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@index([tenantId, name])
}

model InventoryItem {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId  String?
  supplier    Supplier?          @relation(fields: [supplierId], references: [id])

  name        String
  sku         String?
  description String?
  category    String?
  quantity    Int                @default(0)
  minQuantity Int                @default(0)
  unitPrice   Decimal            @default(0)
  costPrice   Decimal            @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  serviceOrderItems ServiceOrderItem[]
  movements         InventoryMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
  @@index([tenantId, category])
  @@index([tenantId, quantity])
}

model InventoryMovement {
  id              String        @id @default(cuid())
  tenantId        String
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  type            String        // 'in', 'out'
  quantity        Int
  description     String?
  createdAt       DateTime      @default(now())

  @@index([tenantId, inventoryItemId])
  @@index([tenantId, createdAt])
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  cnpj      String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems InventoryItem[]

  @@index([tenantId, name])
  @@index([tenantId, cnpj])
}

model Partner {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  cnpj        String?
  phone       String?
  email       String?
  contactName String?
  serviceType String?  // funilaria, retífica, ar condicionado, etc.
  address     String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceOrderItems ServiceOrderItem[]

  @@index([tenantId, active])
  @@index([tenantId, serviceType])
  @@index([tenantId, name])
}

model FinancialRecord {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type        String   // 'receivable', 'payable'
  description String
  value       Decimal
  status      String   @default("pending") // pending, paid, cancelled
  dueDate     DateTime
  paidAt      DateTime?
  category    String?
  serviceOrderId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, type, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdAt])
}
